# Optional: ใช้กับ docker-compose สำหรับ MongoDB
# MONGO_ROOT_USER=root
# MONGO_ROOT_PASSWORD=password

# (แนะนำ) ใช้กับ docker-compose.prod.yml
# MONGO_PORT=27017
# API_PORT=3001
# APP_PORT=3000
#
# สำหรับ API container (ค่า default จะชี้ไปที่ service `mongodb`)
# MONGODB_URI=mongodb://root:password@mongodb:27017/order?authSource=admin
#
# สำหรับ Next.js (ถูกนำไป build-time เป็น client env)
# NEXT_PUBLIC_API_BASE_URL=http://localhost:3001
